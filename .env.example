# Environment Variables
# Copy this file to .env.local and fill in the values

# Resend API Key (for contact form email sending)
# Get your key at: https://resend.com
RESEND_API_KEY=

# Site URL (used for SEO/OG tags)
NEXT_PUBLIC_SITE_URL=https://azcomposite.com

# Google Analytics (already configured in code)
# NEXT_PUBLIC_GA_ID=GT-TBVWFS2N

# Microsoft Clarity Project ID (dynamic user tracking)
# Get your ID at: https://clarity.microsoft.com
# NEXT_PUBLIC_CLARITY_ID=xczgw0q5oz
